      "id": "create-refund-endpoint",
      "method": "POST",
      "path": "/api/v1/refunds",
      "idempotent": true,
      "request_schema": {"name": "RefundRequest", "fields": [...]},
      "response_schema": {"name": "RefundResponse", "fields": [...]},
      "errors": [{"status": 409, "reason": "..."}, ...]
    },
    {
      "type": "kafka_producer",
      "topic": "pay-later.gateway.refund.created.out.queue",
      "via_outbox": true,
      "event_schema": {"name": "RefundCreatedEvent", "fields": [...]}
    },
    {
      "type": "migration",
      "tables": [{"schema": "{{ conventions.sql_schema }}", "name": "refund", "columns": [...], "indexes": [...]}]
    }
  ],
  "acceptance_criteria": [
    "POST /api/v1/refunds с валидным телом и Idempotency-Key возвращает 200",
    "Повторный POST с тем же Idempotency-Key возвращает идентичный 200",
    "В таблице outbox появляется запись с topic=...",
    "..."
  ],
  "gaps": [
    {"severity": "high|medium|low", "field": "...", "description": "..."}
  ],
  "primitive_skills_to_use": ["openapi-first-endpoint", "idempotency-handler", "outbox-event", ...],
  "estimated_blast_radius": {
    "modified_modules": ["..."],
    "new_kafka_topics": ["..."],
    "schema_changes": ["..."],
    "breaking_changes": false
  }
